// =============================================================================
// Anelyria Platform — Prisma Schema
// Multi-tenant, MariaDB compatible
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"  // MariaDB uses mysql provider in Prisma
  url      = env("DATABASE_URL")
}

// =============================================================================
// AUTH
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// =============================================================================
// TENANTS
// =============================================================================

model Tenant {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  logo            String?  @db.Text
  primaryColor    String?  @default("#8b5cf6")
  // Custom metric naming
  chiMetricName   String   @default("CHI")
  inkMetricName   String   @default("INK")
  callsMetricName String   @default("Calls")
  coinName        String   @default("Coins")
  // Billing interval
  billingStartDay Int      @default(1)
  billingEndDay   Int      @default(31)
  // Settings
  chiBonusL1      Float    @default(0.80)
  chiBonusL2      Float    @default(0.85)
  chiBonusL3      Float    @default(0.90)
  chiRewardL1     Int      @default(100)
  chiRewardL2     Int      @default(150)
  chiRewardL3     Int      @default(250)
  monthlyCoinBonus Int     @default(50)
  streakDailyCoin Int      @default(5)
  taskAutoApprove Boolean  @default(true)
  allowSelfRegistration Boolean @default(false)
  passwordMinLength Int    @default(10)
  sessionTimeoutMinutes Int @default(480)
  // Status
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  teams           Team[]
  metrics         MetricEntry[]
  tasks           Task[]
  achievements    Achievement[]
  rewards         Reward[]
  redemptions     RewardRedemption[]
  transactions    CoinTransaction[]
  notifications   Notification[]
  importBatches   ImportBatch[]
  auditLogs       AuditLog[]
}

// =============================================================================
// USERS
// =============================================================================

enum Role {
  employee
  team_lead
  manager
  admin
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  email         String
  passwordHash  String   @db.Text
  name          String
  role          Role     @default(employee)
  avatar        String?  @db.Text
  department    String   @default("")
  teamId        String?
  joinedAt      DateTime @default(now())
  streakDays    Int      @default(0)
  active        Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team          Team?    @relation(fields: [teamId], references: [id])
  metrics       MetricEntry[]
  tasks         TaskAssignment[]
  achievements  UserAchievement[]
  transactions  CoinTransaction[]
  redemptions   RewardRedemption[]
  notifications Notification[]
  auditLogs     AuditLog[]
  uploads       ImportBatch[]
  passwordResets PasswordResetToken[]
  accounts      Account[]
  sessions      Session[]

  @@unique([tenantId, employeeId])
  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model Team {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  department String   @default("")
  leadId     String?

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead       User?    @relation(fields: [leadId], references: [id])
  members    User[]
  tasks      Task[]

  @@unique([tenantId, name])
}

// =============================================================================
// METRICS (CHI + INK + Calls)
// =============================================================================

enum ChiType {
  positive
  neutral
  negative
}

enum MetricSource {
  manual
  csv_import
  api
}

model MetricEntry {
  id            String      @id @default(cuid())
  tenantId      String
  employeeId    String
  date          DateTime    @default(now())
  // The three metrics
  chi           ChiType
  ink           Int         @default(0)     // 0-100
  callsPerHour  Float       @default(0)
  // Source tracking
  source        MetricSource
  importBatchId String?
  notes         String?     @db.Text
  category      String?
  createdAt     DateTime    @default(now())

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([tenantId, employeeId, date])
  @@index([tenantId, chi])
}

// =============================================================================
// TASKS
// =============================================================================

enum TaskStatus {
  active
  completed
  expired
  cancelled
}

enum TaskRecurrence {
  daily
  weekly
  monthly
  none
}

model Task {
  id               String        @id @default(cuid())
  tenantId         String
  title            String
  description      String        @default("") @db.Text
  rewardCoins      Int           @default(0)
  startDate        DateTime
  endDate          DateTime
  recurring        Boolean       @default(false)
  recurrence       TaskRecurrence @default(none)
  category         String        @default("general")
  target           Int           @default(1)
  approvalRequired Boolean       @default(false)
  status           TaskStatus    @default(active)
  createdBy        String
  teamId           String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team             Team?         @relation(fields: [teamId], references: [id])
  assignments      TaskAssignment[]

  @@index([tenantId, status])
}

model TaskAssignment {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

// =============================================================================
// COINS & REWARDS
// =============================================================================

enum CoinTxType {
  bonus_chi
  bonus_ink
  bonus_calls
  bonus_level
  task
  achievement
  streak
  redemption
  manual_adjustment
}

model CoinTransaction {
  id            String     @id @default(cuid())
  tenantId      String
  userId        String
  amount        Int
  reason        String     @db.Text
  type          CoinTxType
  balanceAfter  Int
  referenceId   String?
  referenceType String?
  createdAt     DateTime   @default(now())

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
}

enum RewardCategory {
  gift_cards
  merch
  perks
  experiences
  time_off
}

enum RedemptionStatus {
  pending
  approved
  fulfilled
  rejected
}

model Reward {
  id            String            @id @default(cuid())
  tenantId      String
  title         String
  description   String            @default("") @db.Text
  coinPrice     Int
  category      RewardCategory
  image         String?           @db.Text
  stock         Int               @default(0)
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions   RewardRedemption[]
}

model RewardRedemption {
  id          String          @id @default(cuid())
  tenantId    String
  userId      String
  rewardId    String
  coinsSpent  Int
  status      RedemptionStatus @default(pending)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime        @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward      Reward          @relation(fields: [rewardId], references: [id])

  @@index([tenantId, userId, status])
}

// =============================================================================
// ACHIEVEMENTS
// =============================================================================

model Achievement {
  id            String           @id @default(cuid())
  tenantId      String
  title         String
  description   String           @default("") @db.Text
  icon          String           @default("badge-default")
  rewardCoins   Int              @default(0)
  criteria      String
  color         String           @default("from-purple-500 to-violet-600")
  active        Boolean          @default(true)
  createdAt     DateTime         @default(now())

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unlocks       UserAchievement[]

  @@unique([tenantId, criteria])
}

model UserAchievement {
  id            String       @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime     @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement  @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

enum NotificationType {
  achievement
  bonus
  task
  redemption
  metric_import
  password_reset
  system
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  message   String           @db.Text
  type      NotificationType
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, read, createdAt])
}

// =============================================================================
// CSV IMPORTS
// =============================================================================

enum ImportStatus {
  pending
  processing
  completed
  failed
  rolled_back
}

model ImportBatch {
  id            String      @id @default(cuid())
  tenantId      String
  uploadedBy    String
  fileName      String
  totalRows     Int         @default(0)
  validRows     Int         @default(0)
  invalidRows   Int         @default(0)
  duplicateRows Int         @default(0)
  status        ImportStatus @default(pending)
  periodStart   DateTime
  periodEnd     DateTime
  rawContent    String?     @db.Text
  completedAt   DateTime?
  createdAt     DateTime    @default(now())

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rows          CsvImportRow[]
  metrics       MetricEntry[]

  @@index([tenantId, createdAt])
}

model CsvImportRow {
  id            String      @id @default(cuid())
  batchId       String
  employeeId    String?
  email         String?
  employeeName  String?
  date          String?
  chi           String?
  ink           Int?
  callsPerHour  Float?
  notes         String?     @db.Text
  status        String      @default("pending")
  errorReason   String?
  rawLine       String      @db.Text

  batch         ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

// =============================================================================
// AUDIT
// =============================================================================

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  action      String
  entityType  String
  entityId    String
  details     String   @db.Text
  ip          String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
}
