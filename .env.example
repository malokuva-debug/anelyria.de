# =============================================================================
# Anelyria Platform — Environment Configuration
# For MariaDB on Plesk / Any MySQL-compatible host
# =============================================================================

# Application
NODE_ENV=production
PORT=3001
VITE_API_URL=/api
VITE_APP_URL=https://anelyria.de
VITE_APP_MODE=main

# Tenant Database (placeholder for Prisma client generation; real URL set at runtime per-tenant)
DATABASE_URL="mysql://placeholder:placeholder@localhost:3306/anelyria_placeholder"

# Master Database (routing + super admins)
# Plesk format: mysql://user:password@host:3306/database
MASTER_DATABASE_URL="mysql://anelyria_master_user:SECURE_PASSWORD@localhost:3306/anelyria_master"

# Tenant Database root credentials (for provisioning new tenant databases)
MASTER_DB_USER=anelyria_root
MASTER_DB_PASSWORD=your_root_db_password
TENANT_DB_HOST=localhost

# JWT Secret (generate with: openssl rand -base64 48)
JWT_SECRET="change-this-to-a-random-64-char-string"

# Setup Key (for first super admin registration)
SETUP_KEY="change-this-to-a-random-setup-key"

# Email (Plesk SMTP)
SMTP_HOST=smtp.anelyria.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@anelyria.de
SMTP_PASS=your_smtp_password
EMAIL_FROM="noreply@anelyria.de"
EMAIL_FROM_NAME="Anelyria"

# CORS
CORS_ORIGIN=https://anelyria.de,https://app.anelyria.de

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Prisma — use WASM engine for cross-platform Plesk compatibility (AlmaLinux/RHEL)
PRISMA_CLIENT_ENGINE_TYPE=wasm