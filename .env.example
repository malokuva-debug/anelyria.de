# =============================================================================
# Anelyria Platform — Environment Configuration
# For MariaDB on Plesk / Any MySQL-compatible host
# =============================================================================

# Application
NODE_ENV=production
VITE_APP_URL=https://your-domain.com
VITE_APP_NAME="Anelyria"

# Database (MariaDB / MySQL)
# Plesk format: mysql://user:password@host:3306/database
# Local dev:    mysql://root:password@localhost:3306/anelyria
DATABASE_URL="mysql://anelyria_user:SECURE_PASSWORD_HERE@localhost:3306/anelyria_production"

# Auth
AUTH_SECRET="generate-a-64-character-random-string-here"
AUTH_URL=https://your-domain.com

# Email (for password resets, notifications)
# Resend
RESEND_API_KEY="re_your_key_here"
# OR SMTP (Plesk compatible)
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_USER=noreply@your-domain.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="noreply@your-domain.com"
EMAIL_FROM_NAME="Anelyria"

# File uploads (optional)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Feature flags
FEATURE_PWA_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_CSV_IMPORT=true
FEATURE_LEADERBOARDS=true

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
PASSWORD_MIN_LENGTH=10
SESSION_TIMEOUT_MINUTES=480

# Redis (optional - for sessions & caching)
REDIS_URL=""

# Multi-tenant defaults (overridable per tenant in DB)
DEFAULT_CHI_METRIC_NAME="CHI"
DEFAULT_INK_METRIC_NAME="INK"
DEFAULT_CALLS_METRIC_NAME="Calls"
DEFAULT_COIN_NAME="Coins"
