{
  "name": "anelyria-platform",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server/dist/index.js",
    "db:push:master": "npx prisma db push --schema=server/prisma-master/schema.prisma",
    "db:seed:master": "node server/prisma/seed-master.js",
    "db:migrate:master": "npx prisma migrate deploy --schema=server/prisma-master/schema.prisma",
    "db:generate": "npx prisma generate --schema=server/prisma-master/schema.prisma && npx prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.7.0",
    "nodemailer": "^6.9.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "prisma": "^6.5.0"
  }
}