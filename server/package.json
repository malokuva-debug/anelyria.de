{
  "name": "anelyria-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "npx prisma generate --schema=prisma-master/schema.prisma && npx prisma generate --schema=../prisma/schema.prisma",
    "db:push:master": "npx prisma db push --schema=prisma-master/schema.prisma",
    "db:migrate:master": "npx prisma migrate deploy --schema=prisma-master/schema.prisma",
    "db:seed:master": "npx tsx prisma/seed-master.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^6.5.0",
    "typescript": "^5.3.3"
  }
}