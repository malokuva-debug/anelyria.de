// =============================================================================
// Anelyria Platform — Master Schema
// For routing table and super admins
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/master-client"
}

datasource db {
  provider = "mysql"
  url      = env("MASTER_DATABASE_URL")
}

model UserRoute {
  id         String   @id @default(cuid())
  email      String   @unique
  tenantSlug String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
}

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  dbName    String
  dbUser    String
  dbPass    String
  dbHost    String   @default("localhost")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
